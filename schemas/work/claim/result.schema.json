{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gc work claim --json result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ok",
    "id",
    "status",
    "issue_type",
    "assignee"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "id": {
      "type": "string"
    },
    "status": {
      "const": "in_progress"
    },
    "issue_type": {
      "type": "string"
    },
    "assignee": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
