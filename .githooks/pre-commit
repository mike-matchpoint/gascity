#!/usr/bin/env bash
set -euo pipefail

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
staged_web_src=$(git diff --cached --name-only --diff-filter=ACM -- 'cmd/gc/dashboard/web/src/' 'cmd/gc/dashboard/web/index.html' 'cmd/gc/dashboard/web/public/' 'cmd/gc/dashboard/web/package.json' 'cmd/gc/dashboard/web/openapi-ts.config.ts' 'cmd/gc/dashboard/web/vite.config.ts' 'cmd/gc/dashboard/web/tsconfig.json' || true)
staged_docs=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' 'docs/**' 'engdocs/**' 'plans/**' 'specs/**' 'AGENTS.md' 'CONTRIBUTING.md' 'README.md' 'TESTING.md' || true)

if [ -z "$staged_go_files" ] && [ -z "$staged_web_src" ] && [ -z "$staged_docs" ]; then
  exit 0
fi

if [ -n "$staged_go_files" ]; then
  printf '%s\n' "$staged_go_files" | scripts/precommit-format-staged-go
  printf '%s\n' "$staged_go_files" | xargs git add

  make lint-changed LINT_CHANGED_SCOPE=staged LINT_FLAGS="--new-from-rev=HEAD --whole-files --fix" || exit 1
  printf '%s\n' "$staged_go_files" | xargs git add

  # Regenerate the OpenAPI spec from the live Huma API and stage both
  # canonical copies. Keeps the committed spec and the published
  # Mintlify schema in lockstep with whatever the server actually
  # serves.
  go run ./cmd/genspec
  git add internal/api/openapi.json docs/schema/openapi.json docs/schema/openapi.txt

  go generate ./internal/api/genclient
  git add internal/api/genclient/client_gen.go

  # Regenerate the config/schema docs derived from Go structs and
  # stage every generated artifact so commits do not leave the
  # worktree dirty.
  go run ./cmd/genschema
  git add docs/schema/city-schema.json docs/schema/city-schema.txt docs/reference/config.md docs/reference/cli.md

  make vet
  make test-fast-parallel
fi

# Work-order file byte cap (estate law: the 100,000-byte WO dispatch cap).
# Scope mirrors the authoritative harness batch validator axis-6 check
# (matchpoint-loop-harness/campaigns/master_refactor/validate_dag_completeness.py:
# WO_FILE_CAP_BYTES = 100_000; scope = `*.md` directly under
# specs/agent-work-orders/ via a non-recursive glob, so subdirectories —
# including appendices/ companions — are cap-exempt; skip stems README,
# work-order-template, WO-MIGRATION-MANIFEST). An over-cap WO reaches the
# generator TRUNCATED — the tail past 100k bytes is silently sliced from
# dispatch bundles (the wo-file-over-cap failure class). Fix by relocating
# verbatim content to a specs/agent-work-orders/appendices/ companion file
# (the relocation lane GCD-WO-CSC-003 itself uses, commit 60004430), or by
# splitting the WO — never by crossing the cap.
wo_cap_bytes=100000
wo_warn_bytes=99000
staged_wo_files=$(git diff --cached --name-only --diff-filter=ACM -- 'specs/agent-work-orders/' | grep -E '^specs/agent-work-orders/[^/]+\.md$' || true)
if [ -n "$staged_wo_files" ]; then
  wo_cap_failed=0
  while IFS= read -r wo_file; do
    [ -n "$wo_file" ] || continue
    wo_stem=$(basename "$wo_file" .md)
    case "$wo_stem" in
      README|work-order-template|WO-MIGRATION-MANIFEST) continue ;;
    esac
    wo_size=$(git cat-file -s ":$wo_file")
    if [ "$wo_size" -gt "$wo_cap_bytes" ]; then
      echo "ERROR: $wo_file is $wo_size bytes, over the 100,000-byte work-order file cap" >&2
      echo "  (WO_FILE_CAP_BYTES, harness axis-6 file-cap law — an over-cap WO is silently" >&2
      echo "  TRUNCATED in dispatch bundles). Relocate verbatim content to a" >&2
      echo "  specs/agent-work-orders/appendices/ companion (cap-exempt; the lane" >&2
      echo "  GCD-WO-CSC-003 uses) or split the WO. Commit blocked." >&2
      wo_cap_failed=1
    elif [ "$wo_size" -gt "$wo_warn_bytes" ]; then
      echo "warning: $wo_file is $wo_size bytes — within $((wo_cap_bytes - wo_size)) bytes of the" >&2
      echo "  100,000-byte work-order file cap. Plan an appendices/ relocation before the next" >&2
      echo "  amendment (over-cap WOs are silently truncated in dispatch bundles)." >&2
    fi
  done <<EOF
$staged_wo_files
EOF
  if [ "$wo_cap_failed" -ne 0 ]; then
    exit 1
  fi
fi

if [ -n "$staged_docs" ]; then
  make check-docs
fi

# Dashboard SPA rebuild: whenever the spec changes OR the SPA source
# changes, regenerate the TS types, typecheck, and rebuild the compiled
# bundle. Guarded on `npm` availability so contributors without Node
# tooling aren't blocked; CI enforces the full regeneration.
if command -v npm >/dev/null 2>&1; then
  spec_changed=$(git diff --cached --name-only --diff-filter=ACM -- 'internal/api/openapi.json' || true)
  if [ -n "$spec_changed" ] || [ -n "$staged_web_src" ]; then
    # Typecheck BEFORE build: vite's build transpiles TS to JS and
    # silently ignores type errors. The Makefile target also runs the
    # Vitest suite, builds dist/, and smoke-runs the compiled SPA via
    # Vite preview so a bundle that builds but won't serve is caught
    # before CI.
    make dashboard-check dashboard-smoke
    git add -f cmd/gc/dashboard/web/src/generated
    git add cmd/gc/dashboard/web/dist
  fi
else
  echo "warning: npm not on PATH — skipped dashboard SPA typecheck + rebuild. CI will enforce this." >&2
fi
