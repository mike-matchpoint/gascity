{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eval-run-manifest.v1.schema.json",
  "title": "Eval run manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "run_id", "eval_suite", "cohort_ref", "case_results", "aggregate_scores", "threshold", "gate_outcome", "grader", "timestamps", "triage_packets"],
  "properties": {
    "contract": {"enum": ["eval.run_cohort.v1", "eval.replay_step.v1"]},
    "run_id": {"type": "string", "minLength": 1},
    "eval_suite": {"type": "string", "minLength": 1},
    "cohort_ref": {"type": ["string", "null"], "minLength": 1},
    "case_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/caseResult"}},
    "aggregate_scores": {
      "type": "object", "additionalProperties": false,
      "required": ["axes", "case_count"],
      "properties": {
        "axes": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
        "case_count": {"type": "integer", "minimum": 1}
      }
    },
    "threshold": {
      "type": "object", "additionalProperties": false,
      "required": ["metric", "minimum"],
      "properties": {"metric": {"type": "string", "minLength": 1}, "minimum": {"type": "number", "minimum": 0, "maximum": 1}}
    },
    "gate_outcome": {"enum": ["passed", "failed"]},
    "failing_axes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "grader": {
      "type": "object", "additionalProperties": false,
      "required": ["command", "version", "content_sha256"],
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "timestamps": {
      "type": "object", "additionalProperties": false,
      "required": ["started_at", "completed_at"],
      "properties": {"started_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"}}
    },
    "triage_packets": {"type": "array", "items": {"$ref": "#/$defs/triagePacket"}}
  },
  "allOf": [
    {"if": {"properties": {"gate_outcome": {"const": "failed"}}}, "then": {"properties": {"triage_packets": {"minItems": 1}}}},
    {"if": {"properties": {"contract": {"const": "eval.run_cohort.v1"}}}, "then": {"properties": {"cohort_ref": {"type": "string"}}}}
  ],
  "$defs": {
    "artifactRef": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_name", "uri", "content_sha256"],
      "properties": {
        "artifact_name": {"enum": ["manifest.json", "output.json"]},
        "uri": {"type": "string", "minLength": 1},
        "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "rubricScore": {
      "type": "object", "additionalProperties": false,
      "required": ["axis", "score", "evidence_ref"],
      "properties": {"axis": {"type": "string", "minLength": 1}, "score": {"type": "number", "minimum": 0, "maximum": 1}, "evidence_ref": {"type": "string", "minLength": 1}}
    },
    "caseResult": {
      "type": "object", "additionalProperties": false,
      "required": ["case_id", "fixture_id", "fixture_ref", "terminal_status", "domain_commands", "artifact_refs", "score", "rubric_scores", "grading_result_ref"],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "fixture_id": {"type": "string", "pattern": "^STEP#[^#]+#[^#]+$"},
        "fixture_ref": {"type": "string", "minLength": 1},
        "terminal_status": {"type": "string", "minLength": 1},
        "domain_commands": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "artifact_refs": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/artifactRef"}, "allOf": [
          {"contains": {"type": "object", "properties": {"artifact_name": {"const": "manifest.json"}}}, "minContains": 1, "maxContains": 1},
          {"contains": {"type": "object", "properties": {"artifact_name": {"const": "output.json"}}}, "minContains": 1, "maxContains": 1}
        ]},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "rubric_scores": {"type": "array", "items": {"$ref": "#/$defs/rubricScore"}},
        "grading_result_ref": {"type": "string", "minLength": 1}
      }
    },
    "triagePacket": {
      "type": "object", "additionalProperties": false,
      "required": ["eval_suite", "case_id", "prompt_name", "prompt_version", "model", "provider", "run_id", "expected_outcome", "actual_outcome", "score", "threshold", "failure_label", "prompt_input", "redacted_output_excerpt", "trace_excerpt", "scorer_rationale", "eval_artifact_refs", "related_execution", "prior_passing_run", "regression_window", "changed_dependency", "evaluator_limitations", "nondeterministic_variance", "missing_artifacts"],
      "properties": {
        "eval_suite": {"type": "string", "minLength": 1},
        "case_id": {"type": "string", "minLength": 1},
        "prompt_name": {"type": "string", "minLength": 1},
        "prompt_version": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "expected_outcome": {}, "actual_outcome": {},
        "score": {"type": "number"}, "threshold": {"type": "number"},
        "failure_label": {"type": "string", "minLength": 1},
        "prompt_input": {},
        "redacted_output_excerpt": {"type": "string"},
        "trace_excerpt": {"type": "string"},
        "scorer_rationale": {"type": "string", "minLength": 1},
        "eval_artifact_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "related_execution": {"type": ["string", "null"]},
        "prior_passing_run": {"type": ["string", "null"]},
        "regression_window": {"type": ["string", "null"]},
        "changed_dependency": {"type": ["string", "null"]},
        "evaluator_limitations": {"type": "array", "items": {"type": "string"}},
        "nondeterministic_variance": {"type": ["string", "null"]},
        "missing_artifacts": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
